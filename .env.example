# GitHub API Token (for server-side repository, profile, and stats loading)
# Create a Personal Access Token (classic or fine-grained) with `repo` and `read:user` scopes.
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here

# Formspree Form ID (for Contact Form submission)
# Register at https://formspree.io/ and create a new form. Copy the form ID from the integration URL.
NEXT_PUBLIC_FORM_ID=your_formspree_form_id_here
